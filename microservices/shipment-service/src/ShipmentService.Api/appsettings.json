{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=platform;Username=postgres;Password=postgres"
  },
  "Database": {
    "Schema": "shipment"
  },
  "AWS": {
    "Region": "us-east-1",
    "EventBusName": "cloud-native-platform-dev-bus",
    "ShipmentEventsQueueUrl": "https://sqs.us-east-1.amazonaws.com/123456789012/cloud-native-platform-dev-shipment-events-queue"
  },
  "ShipmentConsumer": {
    "MaxMessagesPerPoll": 5,
    "WaitTimeSeconds": 20,
    "FailureBackoffSeconds": 5
  },
  "EventPublishing": {
    "MaxAttempts": 3,
    "BaseDelayMilliseconds": 200
  },
  "PlatformAuth": {
    "AllowDevelopmentJwtPassthrough": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
