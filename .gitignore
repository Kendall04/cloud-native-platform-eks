# Local Terraform and Terragrunt directories
.terraform/
.terragrunt-cache/

# Terraform dependency locks are generated per working directory in this repo.
.terraform.lock.hcl

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# passwords, private keys, and other secrets. These should not be part of version
# control as they are environment-specific and potentially sensitive.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by Terraform apply.
.terraform.tfstate.lock.info

# Ignore CLI configuration files.
.terraformrc
terraform.rc

# Node local dependencies and logs.
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# .NET build outputs.
bin/
obj/
**/bin/
**/obj/

# Lambda packages generated locally by Terraform/archive tooling.
infra/modules/lambda/*.zip
